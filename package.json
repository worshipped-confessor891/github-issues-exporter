{
  "name": "@willh/github-issues-exporter",
  "private": false,
  "version": "0.1.6",
  "description": "Export GitHub issues to JSON via GitHub CLI auth.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "github-issues-exporter": "dist/cli.js"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "help": "bun run src/index.ts -- --help",
    "check": "bun run --check src/index.ts",
    "test": "bun test",
    "build": "bun build src/index.ts src/cli.ts --outdir dist --target node --format esm && bun run scripts/fix-cli-entry.ts",
    "bump": "bun run scripts/bump.ts",
    "publish:seed": "pwsh -ExecutionPolicy Bypass -File scripts/seed-publish.ps1 -Version 0.1.0 -Tag latest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doggy8088/github-issues-exporter.git"
  },
  "homepage": "https://github.com/doggy8088/github-issues-exporter",
  "bugs": {
    "url": "https://github.com/doggy8088/github-issues-exporter/issues"
  },
  "files": [
    "dist/index.js",
    "dist/cli.js",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
